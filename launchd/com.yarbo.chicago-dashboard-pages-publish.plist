  <array>
    <string>/bin/sh</string>
    <string>/Users/mac/Library/Application Support/YarboChicagoDashboard/chicago-dashboard-publish/scripts/sync_and_publish.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>10</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>/Users/mac/Library/Application Support/YarboChicagoDashboard/logs/github-pages-publish.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/mac/Library/Application Support/YarboChicagoDashboard/logs/github-pages-publish.err.log</string>
</dict>
</plist>
